# AutoViral 环境变量配置
# 复制此文件为 .env 并填入你的密钥
# cp .env.example .env

# ── 即梦 AI（必填，用于生成图片和视频）──────────────────────
# 申请地址：https://console.volcengine.com/iam/keymanage/
JIMENG_ACCESS_KEY=
JIMENG_SECRET_KEY=

# ── OpenRouter（可选，备用 LLM 提供商）─────────────────────
# 申请地址：https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ── EverMemOS（可选，长期记忆系统）─────────────────────────
EVERMEMOS_API_KEY=
