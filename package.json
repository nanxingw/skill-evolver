{
  "name": "@nanxingw/autocode-cli",
  "version": "0.2.0",
  "description": "AutoCode — Self-evolving intelligence for Claude Code: skills, memory, and autonomous tasks",
  "type": "module",
  "bin": {
    "autocode": "dist/index.js",
    "autoviral": "dist/index.js"
  },
  "files": [
    "dist/",
    "skills/",
    "web/dist/"
  ],
  "scripts": {
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "tsc",
    "build:frontend": "vite build",
    "dev": "tsc --watch",
    "dev:frontend": "vite dev",
    "postinstall": "node dist/postinstall.js",
    "test": "vitest run"
  },
  "keywords": [
    "claude-code",
    "autocode",
    "autoviral",
    "ai",
    "agent",
    "automation",
    "claude"
  ],
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@types/dompurify": "^3.0.5",
    "commander": "^12.0.0",
    "dompurify": "^3.3.3",
    "dotenv": "^16.4.0",
    "highlight.js": "^11.11.1",
    "hono": "^4.0.0",
    "js-yaml": "^4.1.0",
    "marked": "^17.0.4",
    "node-cron": "^3.0.0",
    "playwright": "^1.58.2",
    "ws": "^8.0.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.0",
    "@types/ws": "^8.5.0",
    "svelte": "^5.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nanxingw/autocode.git"
  },
  "publishConfig": {
    "access": "public"
  }
}
